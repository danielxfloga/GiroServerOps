<UserControl x:Class="NetcoServerConsole.QuerySqlView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:NetcoServerConsole"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <UserControl.Resources >
        <SolidColorBrush x:Key="WindowBg" Color="#111315"/>
        <SolidColorBrush x:Key="PanelBg" Color="#FF303030"/>
        <SolidColorBrush x:Key="PanelInnerBg" Color="#FF202020"/>
        <SolidColorBrush x:Key="PanelSoftBg" Color="#FF202020"/>
        <SolidColorBrush x:Key="TextMain" Color="#F4F7FB"/>
        <SolidColorBrush x:Key="TextMuted" Color="#A8B2C0"/>
        <SolidColorBrush x:Key="TextDim" Color="#7B8593"/>
        <SolidColorBrush x:Key="GridBg" Color="#FF202020"/>
        <SolidColorBrush x:Key="GridHeaderBg" Color="#FF202020"/>
        <SolidColorBrush x:Key="GridLine" Color="#2D3440"/>
        
        <SolidColorBrush x:Key="InputBg" Color="#FF050505"/>
        <SolidColorBrush x:Key="InputBorder" Color="#2B3440"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#5AC8FA"/>
        <SolidColorBrush x:Key="AccentViolet" Color="#A85BFF"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#56E39F"/>
        <SolidColorBrush x:Key="AccentAmber" Color="#FFB454"/>
        <LinearGradientBrush x:Key="LogoGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#5EC8FF" Offset="0"/>
            <GradientStop Color="#8B5CFF" Offset="0.26"/>
            <GradientStop Color="#4DE2A8" Offset="0.52"/>
            <GradientStop Color="#F6D04D" Offset="0.76"/>
            <GradientStop Color="#FF7A59" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="LogoGradientSoft" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#CC5EC8FF" Offset="0"/>
            <GradientStop Color="#CC8B5CFF" Offset="0.26"/>
            <GradientStop Color="#CC4DE2A8" Offset="0.52"/>
            <GradientStop Color="#CCF6D04D" Offset="0.76"/>
            <GradientStop Color="#CCFF7A59" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="TitleTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="FontSize" Value="19"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="SubtitleTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="FontSize" Value="12.5"/>
        </Style>

        <Style x:Key="CaptionTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="GradientButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="Background" Value="#FF202020"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{StaticResource TextMain}" CornerRadius="12" Padding="1">
                            <Border x:Name="Inner"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="11">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Inner" Property="Background" Value="#1B2330"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Inner" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Inner" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource GradientButtonStyle}">
            <Setter Property="Background" Value="#FF202020"/>
        </Style>

        <Style x:Key="StopButtonStyle" TargetType="Button" BasedOn="{StaticResource GradientButtonStyle}">
            <Setter Property="Background" Value="#4A1717"/>
            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style x:Key="GradientTextBoxStyle" TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="SelectionBrush" Value="#55FFFFFF"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="SpellCheck.IsEnabled" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{StaticResource InputBg}" CornerRadius="16" Padding="1">
                            <Border Background="{StaticResource InputBg}" CornerRadius="15" Padding="14">
                                <ScrollViewer x:Name="PART_ContentHost" Background="{StaticResource InputBg}"/>
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GradientCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="26"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="18" Height="18" VerticalAlignment="Center" CornerRadius="5" Background="{StaticResource TextMain}" Margin="0,0,8,0">
                                <Border x:Name="CheckBorder" Margin="1" CornerRadius="4" Background="#FF505050" BorderBrush="#2B3440" BorderThickness="1">
                                    <Path x:Name="CheckMark" Data="M 3 9 L 7 13 L 14 5" StrokeThickness="2.2" Stroke="White" Stretch="Fill" Margin="3" Visibility="Collapsed"/>
                                </Border>
                            </Border>
                            <ContentPresenter Grid.Column="1" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckBorder" Property="Background" Value="#203249"/>
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#5EC8FF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GradientTabItemStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="Background" Value="#161B22"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Background="{StaticResource TextDim}" CornerRadius="12" Padding="1" SnapsToDevicePixels="True" Margin="0,0,10,0">
                            <Border x:Name="Inner" Background="#FF202020" CornerRadius="11">
                                <ContentPresenter ContentSource="Header"
                                          Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True"/>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
                                <Setter TargetName="Inner" Property="Background" Value="#FF505050"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Inner" Property="Background" Value="#FF505050"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TransparentRepeatButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

         <Style x:Key="GradientScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="MinWidth" Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="#FF4A4A4A" CornerRadius="6" Margin="0,0,0,0"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="VerticalScrollBarTemplate" TargetType="ScrollBar">
            <Border Background="{StaticResource GridHeaderBg}" CornerRadius="7" Padding="2" SnapsToDevicePixels="True">
                <Track x:Name="PART_Track"
               Orientation="Vertical"
               IsDirectionReversed="True"
               Minimum="{TemplateBinding Minimum}"
               Maximum="{TemplateBinding Maximum}"
               Value="{Binding Value, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
               ViewportSize="{TemplateBinding ViewportSize}">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Command="ScrollBar.PageUpCommand"
                              Style="{StaticResource TransparentRepeatButtonStyle}"/>
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource GradientScrollBarThumbStyle}"/>
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Command="ScrollBar.PageDownCommand"
                              Style="{StaticResource TransparentRepeatButtonStyle}"/>
                    </Track.IncreaseRepeatButton>
                </Track>
            </Border>
        </ControlTemplate>

        <ControlTemplate x:Key="HorizontalScrollBarTemplate" TargetType="ScrollBar">
            <Border Background="{StaticResource GridHeaderBg}" CornerRadius="7" Padding="2" SnapsToDevicePixels="True">
                <Track x:Name="PART_Track"
               Orientation="Horizontal"
               Minimum="{TemplateBinding Minimum}"
               Maximum="{TemplateBinding Maximum}"
               Value="{Binding Value, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
               ViewportSize="{TemplateBinding ViewportSize}">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Command="ScrollBar.PageLeftCommand"
                              Style="{StaticResource TransparentRepeatButtonStyle}"/>
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource GradientScrollBarThumbStyle}"/>
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Command="ScrollBar.PageRightCommand"
                              Style="{StaticResource TransparentRepeatButtonStyle}"/>
                    </Track.IncreaseRepeatButton>
                </Track>
            </Border>
        </ControlTemplate>

        <Style x:Key="GradientScrollBarStyle" TargetType="ScrollBar">
            <Setter Property="Background" Value="{StaticResource GridHeaderBg}"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Template" Value="{StaticResource VerticalScrollBarTemplate}"/>
                    <Setter Property="Width" Value="14"/>
                    <Setter Property="VerticalAlignment" Value="Stretch"/>
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Template" Value="{StaticResource HorizontalScrollBarTemplate}"/>
                    <Setter Property="Height" Value="14"/>
                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                </Trigger>
            </Style.Triggers>
        </Style>


        <Style TargetType="ScrollBar" BasedOn="{StaticResource GradientScrollBarStyle}"/>
        <Style x:Key="DarkDataGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource GridHeaderBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="BorderBrush" Value="{StaticResource GridLine}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="{StaticResource GridHeaderBg}"/>
            <Setter Property="AlternatingRowBackground" Value="#FF181818"/>
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource GridLine}"/>
            <Setter Property="VerticalGridLinesBrush" Value="{StaticResource GridLine}"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="EnableRowVirtualization" Value="True"/>
            <Setter Property="EnableColumnVirtualization" Value="True"/>
            <Setter Property="SelectionMode" Value="Extended"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
            <Setter Property="ScrollViewer.PanningMode" Value="Both"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>
            <Setter Property="VirtualizingPanel.IsVirtualizingWhenGrouping" Value="True"/>
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource GridHeaderBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="BorderBrush" Value="{StaticResource GridLine}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource GridLine}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FF101010"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="FlatTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid ClipToBounds="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TabPanel Grid.Row="0"
                              IsItemsHost="True"
                              Background="Transparent"
                              Margin="0,0,0,12"/>

                            <ContentPresenter Grid.Row="1"
                                      ContentSource="SelectedContent"
                                      Margin="0"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="#10151C"/>
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF000000"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FF202020"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PanelHostStyle" TargetType="Grid">
            <Setter Property="Margin" Value="0"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="250"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.Column="0" Background="{StaticResource TextDim}" CornerRadius="22" Padding="1">
            <Border Background="{StaticResource PanelBg}" CornerRadius="21" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Bases de datos" Style="{StaticResource TitleTextStyle}"/>
                        <TextBlock Grid.Row="1" Margin="0,6,0,0" Text="Selecciona una o varias bases donde se ejecutarÃ¡ la consulta." Style="{StaticResource SubtitleTextStyle}" TextWrapping="Wrap"/>
                    </Grid>

                    <WrapPanel Grid.Row="1" Margin="0,16,0,0">
                        <Button Content="Cargar" Style="{StaticResource GradientButtonStyle}" Click="ReloadDatabases_Click"/>
                        <Button Content="Todas" Style="{StaticResource GradientButtonStyle}" Click="SelectAllDatabases_Click"/>
                        <Button Content="Ninguna" Style="{StaticResource GradientButtonStyle}" Click="ClearDatabases_Click" Margin="0"/>
                    </WrapPanel>

                    <Border Grid.Row="2" Margin="0,16,0,0" Background="{StaticResource TextMain}" CornerRadius="18" Padding="1">
                        <Border Background="{StaticResource PanelInnerBg}" CornerRadius="17" Padding="0" ClipToBounds="True">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  CanContentScroll="False"
                                  Padding="12">
                                <ItemsControl ItemsSource="{Binding Databases}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected, Mode=TwoWay}" Style="{StaticResource GradientCheckBoxStyle}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </Border>
                </Grid>
            </Border>
        </Border>

        <Border Grid.Row="0" Grid.Column="2" Background="{StaticResource TextDim}" CornerRadius="22" Padding="1">
            <Border Background="{StaticResource PanelBg}" CornerRadius="21" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DockPanel LastChildFill="True">
                        <TextBlock Text="QUERY SQL" Style="{StaticResource TitleTextStyle}" VerticalAlignment="Center"/>
                        <WrapPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                            <Button x:Name="btnStopExecution"
                                    Style="{StaticResource StopButtonStyle}"
                                    Visibility="Collapsed"
                                    ToolTip="Detener consulta"
                                    Click="StopExecution_Click">
                                <Viewbox Width="12" Height="12">
                                    <Rectangle Width="10" Height="10" Fill="White" RadiusX="1" RadiusY="1"/>
                                </Viewbox>
                            </Button>
                            <Button x:Name="btnExecute" Content="Ejecutar" Style="{StaticResource AccentButtonStyle}" Click="Execute_Click"/>
                            <Button Content="Limpiar" Style="{StaticResource GradientButtonStyle}" Margin="0" Click="ClearQuery_Click"/>
                        </WrapPanel>
                    </DockPanel>

                    <TextBox x:Name="txtQuery"
                             Grid.Row="1"
                             Margin="0,16,0,0"
                             Style="{StaticResource GradientTextBoxStyle}"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             Text="SELECT TOP 100 name, database_id FROM sys.databases ORDER BY name;"/>

                    <DockPanel Grid.Row="2" Margin="0,14,0,0" LastChildFill="True">
                        <TextBlock x:Name="txtStatus" Text="Listo." Foreground="{StaticResource TextMuted}" FontSize="12.5" VerticalAlignment="Center"/>
                    </DockPanel>
                </Grid>
            </Border>
        </Border>

        <Border Grid.Row="2" Grid.ColumnSpan="3" Background="{StaticResource LogoGradient}" CornerRadius="22" Padding="1">
            <Border Background="{StaticResource PanelBg}" CornerRadius="21" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DockPanel LastChildFill="True">
                        <TextBlock Text="Resultados" Style="{StaticResource TitleTextStyle}" VerticalAlignment="Center"/>
                        <WrapPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                            <Button x:Name="btnCopyWithHeaders"
                                    Content="Copiar"
                                    Style="{StaticResource GradientButtonStyle}"
                                    Margin="0"
                                    IsEnabled="False"
                                    Click="CopyWithHeaders_Click"/>
                        </WrapPanel>
                    </DockPanel>

                    <TabControl x:Name="tabResult"
            Grid.Row="1"
            Margin="0,16,0,0"
            MinHeight="280"
            SelectedIndex="1"
            Style="{StaticResource FlatTabControlStyle}"
            Background="Transparent"
            BorderThickness="0"
            Foreground="{StaticResource TextMain}">
                        <TabControl.Resources>
                            <Style TargetType="TabItem" BasedOn="{StaticResource GradientTabItemStyle}"/>
                        </TabControl.Resources>

                        <TabItem Header="Resultados">
                            <Border Background="{StaticResource TextDim}" CornerRadius="18" Padding="1">
                                <Border Background="{StaticResource GridHeaderBg}"
                    CornerRadius="17"
                    ClipToBounds="True"
                    SnapsToDevicePixels="True">
                                    <DataGrid x:Name="gridResult"
                                      Style="{StaticResource DarkDataGridStyle}"
                                      Margin="0"
                                      IsReadOnly="True"
                                      ClipboardCopyMode="IncludeHeader"
                                      Background="{StaticResource GridHeaderBg}"
                                      RowBackground="{StaticResource GridHeaderBg}"
                                      AlternatingRowBackground="#FF181818"
                                      BorderThickness="0"
                                      AutoGenerateColumns="False"
                                      EnableRowVirtualization="True"
                                      EnableColumnVirtualization="True"
                                      ScrollViewer.CanContentScroll="True"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling">
                                        <DataGrid.Resources>
                                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#FF202020"/>
                                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#FF202020"/>
                                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFFFFFFF"/>
                                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#FFFFFFFF"/>
                                            <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#FF202020"/>
                                            <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#FF202020"/>
                                        </DataGrid.Resources>
                                    </DataGrid>
                                </Border>
                            </Border>
                        </TabItem>

                        <TabItem Header="Mensajes">
                            <Border Background="{StaticResource TextDim}" CornerRadius="18" Padding="1">
                                <Border Background="{StaticResource PanelInnerBg}" CornerRadius="17" Padding="0" ClipToBounds="True">
                                    <TextBox x:Name="txtResult"
                         Margin="0"
                         Padding="14"
                         Style="{StaticResource GradientTextBoxStyle}"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         MinHeight="240"
                         Text="Sin resultados todavía."/>
                                </Border>
                            </Border>
                        </TabItem>
                    </TabControl>

                    <DockPanel Grid.Row="2" Margin="0,14,0,0" LastChildFill="True">
                        <TextBlock x:Name="txtFooter" Text="" Foreground="{StaticResource TextMuted}" FontSize="12.5" VerticalAlignment="Center"/>
                    </DockPanel>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
